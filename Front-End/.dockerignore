# ═══════════════════════════════════════════════════════════════
# WIDAD-TECH — Frontend .dockerignore
# ═══════════════════════════════════════════════════════════════

# ── Git ──────────────────────────────────────────────────────
.git
.gitignore

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Build output (built fresh in container) ───────────────────
dist/
dist-ssr/

# ── Environment ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/

# ── Test & Debug ─────────────────────────────────────────────
coverage/

# ── Docker ────────────────────────────────────────────────────
Dockerfile
Dockerfile.*

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
